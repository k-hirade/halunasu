# Keep Cloud Build uploads small while preserving all service runtime inputs.
*

# Browser clients are deployed separately and never enter Cloud Run build contexts.
clients/

!cloudbuild.platform-api.yaml
!cloudbuild.node-service.yaml
!package.json

!services/
services/*
!services/node-service.Dockerfile
!services/*/
services/*/*
!services/*/Dockerfile
!services/*/package.json
!services/*/src/
!services/*/src/**

!packages/
packages/*
!packages/*/
packages/*/*
!packages/*/package.json
!packages/*/src/
!packages/*/src/**
packages/*/README.md
packages/*/test/

!python/
python/*
!python/data/
python/data/*
!python/data/master/
python/data/master/*
!python/data/master/*.sqlite.gz
!python/data/master/*.manifest.json
!python/medical_fee_calculation/
!python/medical_fee_calculation/**

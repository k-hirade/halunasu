{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://halunasu.com/schemas/tests/fee-chart-gold.schema.json",
  "title": "Halunasu Fee Chart Gold Dataset",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "datasetId",
    "version",
    "masterVersion",
    "purpose",
    "difficultyLevels",
    "cases"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "fee-chart-gold.case-set.v1"
    },
    "datasetId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "masterVersion": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "difficultyLevels": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["level", "label", "description"],
        "properties": {
          "level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "caseId",
        "difficulty",
        "title",
        "status",
        "qualityLabel",
        "reviewPolicy",
        "targetBillingFacts",
        "claimContextGold",
        "expectedCalculation",
        "expectedExtraction",
        "chartVariants",
        "evidence"
      ],
      "properties": {
        "caseId": {
          "type": "string",
          "pattern": "^L[1-3]-\\d{3}-[a-z0-9-]+$"
        },
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "master_verified", "office_reviewed", "ci_enabled", "deprecated"]
        },
        "qualityLabel": {
          "type": "string",
          "enum": ["verified", "needs_office_review", "unsupported_expected", "regression_only"]
        },
        "reviewPolicy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "officeReviewed",
            "officeReviewRequired",
            "calculationAssertion",
            "ciEligible",
            "productionGoldAllowed"
          ],
          "properties": {
            "officeReviewed": {
              "type": "boolean"
            },
            "officeReviewRequired": {
              "type": "boolean"
            },
            "calculationAssertion": {
              "type": "string",
              "enum": [
                "exact",
                "candidate_presence",
                "review_required",
                "unsupported_expected",
                "safety",
                "split_required"
              ]
            },
            "ciEligible": {
              "type": "boolean"
            },
            "productionGoldAllowed": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "targetBillingFacts": {
          "type": "object",
          "additionalProperties": true,
          "required": ["patient", "encounter", "diagnoses", "billingTargets", "reviewTargets"],
          "properties": {
            "patient": {
              "type": "object"
            },
            "encounter": {
              "type": "object"
            },
            "diagnoses": {
              "type": "array",
              "items": {"type": "string"}
            },
            "billingTargets": {
              "type": "array",
              "items": {"$ref": "#/$defs/billingTarget"}
            },
            "reviewTargets": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "claimContextGold": {
          "anyOf": [
            {"type": "null"},
            {"type": "object"}
          ]
        },
        "expectedCalculation": {
          "type": "object",
          "additionalProperties": true,
          "required": ["assertionLevel", "engineStatus"],
          "properties": {
            "assertionLevel": {
              "type": "string",
              "enum": [
                "exact",
                "candidate_presence",
                "review_required",
                "unsupported_expected",
                "safety",
                "split_required"
              ]
            },
            "engineStatus": {
              "type": "string",
              "enum": ["ok", "needs_review", "error"]
            },
            "totalPoints": {
              "anyOf": [
                {"type": "number"},
                {"type": "null"}
              ]
            },
            "candidateCodes": {
              "type": "array",
              "items": {"type": "string"}
            },
            "minimumCandidateCodes": {
              "type": "array",
              "items": {"type": "string"}
            },
            "forbiddenCandidateCodes": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "expectedExtraction": {
          "type": "object",
          "additionalProperties": true,
          "required": ["requiredDiagnoses", "requiredReviewTopics", "forbiddenCandidates"],
          "properties": {
            "requiredDiagnoses": {
              "type": "array",
              "items": {"type": "string"}
            },
            "requiredProcedureCandidates": {
              "type": "array",
              "items": {"type": "string"}
            },
            "requiredMedicationCandidates": {
              "type": "array",
              "items": {"type": "string"}
            },
            "requiredReviewTopics": {
              "type": "array",
              "items": {"type": "string"}
            },
            "forbiddenCandidates": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "chartVariants": {
          "type": "object",
          "required": ["soap", "standard"],
          "properties": {
            "soap": {
              "type": "object",
              "required": ["S", "O", "A", "P"],
              "properties": {
                "S": {"type": "array", "items": {"type": "string"}},
                "O": {"type": "array", "items": {"type": "string"}},
                "A": {"type": "array", "items": {"type": "string"}},
                "P": {"type": "array", "items": {"type": "string"}}
              }
            },
            "standard": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidence"}
        },
        "engineVerification": {
          "type": "object"
        }
      }
    },
    "billingTarget": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "code": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "points": {
          "type": "number",
          "description": "単位点数または基礎点数。数量・丸め後の行合計は totalPoints に入れる。薬剤では薬価円/10 の単位点数を入れる。"
        },
        "unitPoints": {
          "type": "number",
          "description": "points が単位点数であることを明示したい場合の補助フィールド。"
        },
        "quantity": {
          "type": "number"
        },
        "quantityUnit": {
          "type": "string"
        },
        "totalPoints": {
          "type": "number",
          "description": "数量反映・薬剤丸め後の行合計点。exactケースの合計検証ではこの値を優先する。"
        },
        "unitAmountYen": {
          "type": "number"
        },
        "totalDrugPriceYen": {
          "type": "number"
        },
        "rounding": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "source",
        "masterVersion",
        "verifiedBy",
        "verifiedAt",
        "verificationMethod"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["medical_procedure_master", "drug_master", "unsupported_policy"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "masterVersion": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "code": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "points": {
          "type": "number",
          "description": "単位点数または基礎点数。数量・丸め後の行合計は totalPoints に入れる。"
        },
        "unitPoints": {
          "type": "number"
        },
        "verifiedBy": {
          "type": "string"
        },
        "verifiedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "verificationMethod": {
          "type": "string"
        },
        "unitAmountYen": {
          "type": "number"
        },
        "totalDrugPriceYen": {
          "type": "number"
        },
        "totalPoints": {
          "type": "number"
        },
        "rounding": {
          "type": "string"
        }
      }
    }
  }
}

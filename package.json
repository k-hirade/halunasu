{
  "name": "halunasu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:runtime-apps": "node scripts/p11_build_static_apps_runtime_config.mjs",
    "deploy:netlify-static": "node scripts/p13_deploy_netlify_static_apps.mjs",
    "deploy:netlify-charting-next": "node scripts/p16_deploy_charting_next_netlify.mjs",
    "deploy:netlify-admin-fee-next": "node scripts/p18_deploy_admin_fee_next_netlify.mjs",
    "deploy:firestore:plan": "scripts/p17_deploy_firestore_security_and_indexes.sh",
    "deploy:firestore:apply": "scripts/p17_deploy_firestore_security_and_indexes.sh --apply",
    "seed:core-account": "node scripts/p15_seed_core_account.mjs",
    "test": "npm run test --workspaces --if-present",
    "test:web:e2e": "node apps/charting-web/test/e2e/run-e2e.js",
    "test:coverage": "node --test --experimental-test-coverage \"--test-coverage-include=packages/*/src/**/*.js\" --test-coverage-exclude=packages/medical-core/src/store/firestore-store.js --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=68 \"packages/**/*.test.js\"",
    "test:coverage:target": "node --test --experimental-test-coverage \"--test-coverage-include=packages/*/src/**/*.js\" --test-coverage-exclude=packages/medical-core/src/store/firestore-store.js --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=85 \"packages/**/*.test.js\"",
    "test:python": "PYTHONPATH=python python3 -m unittest discover -s python/tests",
    "test:python:legacy-fee": "PYTHONPATH=python python3 -m unittest discover -s python/tests/legacy_medical_fee_calculation",
    "test:fee-gold": "node scripts/validate_fee_gold_dataset.mjs",
    "test:fee-gold:engine": "node scripts/validate_fee_gold_dataset.mjs --engine",
    "generate:fee-gold": "node scripts/generate_fee_gold_seed_300.mjs",
    "test:fee-soap-e2e": "node scripts/validate_fee_soap_e2e_dataset.mjs",
    "generate:fee-soap-e2e": "node scripts/generate_fee_soap_e2e_cases.mjs",
    "eval:fee-soap-e2e": "node scripts/evaluate_fee_soap_e2e_dataset.mjs",
    "eval:fee-soap-e2e:strict": "node scripts/evaluate_fee_soap_e2e_dataset.mjs --strict",
    "eval:fee-soap-e2e:stg": "node scripts/evaluate_fee_soap_e2e_dataset.mjs --mode stg",
    "build:fee-master": "PYTHONPATH=python python3 scripts/build_fee_master_official.py",
    "audit:fee-master": "PYTHONPATH=python python3 scripts/audit_fee_master_coverage.py",
    "audit:migration-parity": "node scripts/migration_parity_check.mjs --report-only",
    "test:migration-parity": "node scripts/migration_parity_check.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "docs:manual:html": "node docs/migration-parity/charting-legacy-docs/manuals/scripts/build-pdf.mjs --html-only",
    "docs:manual:pdf": "node docs/migration-parity/charting-legacy-docs/manuals/scripts/build-pdf.mjs",
    "docs:manual:screenshots": "node docs/migration-parity/charting-legacy-docs/manuals/scripts/capture-screenshots.mjs",
    "check:openai-realtime": "node scripts/check_openai_realtime_transcription.mjs",
    "check:openai-final": "node scripts/check_openai_final_transcription.mjs",
    "check:openai-soap": "node scripts/check_openai_soap_pipeline.mjs",
    "ops:billing-maintenance": "node scripts/run_platform_billing_maintenance.mjs",
    "ops:retention:dry-run": "node scripts/run_retention_cleanup.mjs",
    "ops:retention:apply": "node scripts/run_retention_cleanup.mjs --apply",
    "ops:mfa-reset": "node scripts/reset_member_mfa.mjs",
    "start:platform-api": "npm run start --workspace @halunasu/platform-api",
    "dev:platform-api": "npm run dev --workspace @halunasu/platform-api",
    "start:charting-api": "npm run start --workspace @halunasu/charting-api",
    "dev:charting-api": "npm run dev --workspace @halunasu/charting-api",
    "start:charting-gateway": "npm run start --workspace @halunasu/charting-gateway",
    "dev:charting-gateway": "npm run dev --workspace @halunasu/charting-gateway",
    "start:charting-finalize": "npm run start --workspace @halunasu/charting-finalize",
    "dev:charting-finalize": "npm run dev --workspace @halunasu/charting-finalize",
    "start:charting-finalize-legacy": "npm run start --workspace @halunasu/charting-finalize-legacy",
    "dev:charting-finalize-legacy": "npm run dev --workspace @halunasu/charting-finalize-legacy",
    "start:billing-api-legacy": "npm run start --workspace @halunasu/billing-api-legacy",
    "dev:billing-api-legacy": "npm run dev --workspace @halunasu/billing-api-legacy",
    "start:fee-api": "npm run start --workspace @halunasu/fee-api",
    "dev:fee-api": "npm run dev --workspace @halunasu/fee-api",
    "start:referral-api": "npm run start --workspace @halunasu/referral-api",
    "dev:referral-api": "npm run dev --workspace @halunasu/referral-api"
  }
}

# Shared local defaults
NODE_ENV=development
HALUNASU_ENV=local
GOOGLE_CLOUD_PROJECT=medical-core-stg
GOOGLE_CLOUD_REGION=asia-northeast1
APP_BASE_URL=http://localhost:3000

# Platform API
PLATFORM_API_PORT=8080
PLATFORM_STORE_BACKEND=memory
CORE_GOOGLE_CLOUD_PROJECT=medical-core-stg
APP_SESSION_SIGNING_SECRET=replace-me
CSRF_SIGNING_SECRET=replace-me
APP_FIELD_ENCRYPTION_KEY=

# Platform signup / billing / mail
LP_BASE_URL=http://localhost:3000
CORE_ADMIN_BASE_URL=http://localhost:3001
EMAIL_DELIVERY_PROVIDER=console
EMAIL_FROM_ADDRESS="Halunasu <no-reply@mail.halunasu.com>"
EMAIL_REPLY_TO_ADDRESS=info@halunasu.com
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-03-25.dahlia
STRIPE_PRICE_LOOKUP_KEY=medical_ai_monthly_jpy_v2

# Charting gateway
GATEWAY_PORT=8081
STORE_BACKEND=memory
PLATFORM_STORE_BACKEND=memory
PLATFORM_GOOGLE_CLOUD_PROJECT=medical-core-stg
CHARTING_GATEWAY_PLATFORM_AUTH_BRIDGE=true
PAIRING_SIGNING_SECRET=replace-me
APP_REQUIRE_PRIVILEGED_MFA=true
APP_ALLOW_OPERATOR_BEARER_AUTH=false

# Charting finalize path
FINALIZE_MODE=inline
FINALIZE_ENDPOINT=http://localhost:8082/internal/finalize
FINALIZE_INTERNAL_SECRET=
FINALIZE_TASKS_QUEUE=
FINALIZE_TASKS_LOCATION=asia-northeast1
FINALIZE_TASKS_PROJECT_ID=
FINALIZE_TASKS_SERVICE_ACCOUNT_EMAIL=
FINALIZE_PORT=8082
FINAL_TRANSCRIPT_SEGMENT_PRECOMPUTE_ENABLED=true

# Optional raw audio GCS path. Not required for low-cost inline operation.
RAW_AUDIO_GCS_BUCKET=
RAW_AUDIO_GCS_PREFIX=raw-audio
ARTIFACT_BUCKET=
AUDIO_BUCKET=

# Live STT. Deepgram is optional; OpenAI is the primary path for current deployment.
LIVE_STT_MODE=provider
LIVE_STT_PROVIDER=openai
LIVE_STT_FALLBACK_PROVIDER=
LIVE_STT_ALLOW_MOCK_FALLBACK=true
LIVE_STT_REPLAY_BUFFER_BYTES=1000000
LIVE_STT_ARCHIVE_MAX_BYTES=40000000
OPENAI_API_KEY=
OPENAI_REALTIME_WS_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_CLIENT_SECRETS_URL=https://api.openai.com/v1/realtime/client_secrets
OPENAI_REALTIME_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_LANGUAGE=ja
OPENAI_REALTIME_PROMPT=
OPENAI_REALTIME_SAMPLE_RATE_HZ=24000
OPENAI_REALTIME_CHANNELS=1
OPENAI_REALTIME_TURN_DETECTION=server_vad
OPENAI_REALTIME_INCLUDE_LOGPROBS=false
OPENAI_FINAL_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_FINAL_TRANSCRIBE_LANGUAGE=ja
OPENAI_FACT_MODEL=gpt-5.4-nano
OPENAI_FACT_REASONING_EFFORT=low
OPENAI_FEE_CLINICAL_MODEL=gpt-5.4-nano
OPENAI_FEE_CLINICAL_REASONING_EFFORT=low
OPENAI_FEE_CLINICAL_TIMEOUT_MS=12000
OPENAI_SOAP_MODEL=gpt-5.4-nano
OPENAI_SOAP_REASONING_EFFORT=low
DEEPGRAM_API_KEY=
DEEPGRAM_WS_URL=wss://api.deepgram.com/v1/listen
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=ja
DEEPGRAM_INTERIM_RESULTS=true
DEEPGRAM_PUNCTUATE=true
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_ENDPOINTING_MS=300

# Charting web
GATEWAY_BASE_URL=http://localhost:8081
NEXT_PUBLIC_GATEWAY_BASE_URL=http://localhost:8081
GATEWAY_PROXY_TARGET=http://localhost:8081
GATEWAY_WS_URL=ws://localhost:8081/ws
NEXT_PUBLIC_GATEWAY_WS_URL=ws://localhost:8081/ws
BILLING_BASE_URL=/billing
NEXT_PUBLIC_BILLING_BASE_URL=/billing
BILLING_PROXY_TARGET=http://localhost:8080

# Fee / Referral local APIs
FEE_API_PORT=8083
REFERRAL_API_PORT=8084
